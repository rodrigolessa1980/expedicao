NODE_ENV=development
PORT=2515
JWT_SECRET=troque-este-segredo
JWT_EXPIRES_IN=12h
CORS_ORIGIN=http://localhost:5772
# Uma URL para links em e-mail (confirmar conta / senha). Nao copie lista do CORS aqui; se precisar de varias origens, use so a URL publica.
FRONTEND_URL=http://localhost:5772
EMAIL_WEBHOOK_URL=http://localhost:3000/api/email/webhook
# Producao n8n (workflow PRECISA estar ativo no n8n, senao retorna 404 "not registered")
# ATRASO_PEDIDO_WEBHOOK_URL=https://dadosbi.monkeybranch.com.br/webhook/atrasonopedido
# Dev: use a Test URL do node Webhook no n8n enquanto o fluxo de producao nao estiver ativo
ATRASO_PEDIDO_DIAS_ATRASO=1
ATRASO_PEDIDO_WEBHOOK_SECRET=troque-este-segredo-do-fluxo-externo
ATRASO_PEDIDO_JOB_ENABLED=true
ATRASO_PEDIDO_JOB_INTERVAL_MS=3600000
ATRASO_PEDIDO_JOB_RUN_ON_START=true
DB_HOST=localhost
DB_PORT=3306
DB_NAME=expedicao
DB_USER=root
DB_PASSWORD=root
DATABASE_URL=mysql://root:root@localhost:3306/expedicao
